# ── Splashdeals Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
# Runtime queries can use the Neon pooler host (*-pooler.*).
DATABASE_URL="postgresql://user:***@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require"
# Prefer a non-pooler URL for prisma migrate deploy (avoids P1002 advisory-lock timeouts on Vercel).
# If unset, scripts/prisma-migrate-deploy.mjs derives one by stripping "-pooler" from DATABASE_URL.
# DIRECT_URL="postgresql://user:***@ep-xxx.region.aws.neon.tech/db?sslmode=require"

# ── Stripe (Payment Processing) ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.splashdeals.rs
# English hreflang in sitemap/page alternates — enable ONLY when /en/* is live + indexable
# SEO_ENABLE_EN_HREFLANG=true

# ── Apple Wallet ─────────────────────────────────────────────────────────────
PASS_TYPE_IDENTIFIER=pass.com.splashdeals.ticket
TEAM_IDENTIFIER=
APPLE_WALLET_CERT=
APPLE_WALLET_KEY=

# ── Optional: for E2E tests (see e2e/checkout.spec.ts) ───────────────────────
# E2E_BASE_URL=http://localhost:3000

# ── Seeding ──────────────────────────────────────────────────────────────────
# Default password for the seeded admin account (admin@splashdeals.rs)
ADMIN_SEED_PASSWORD=P0w3r-Br0k3r

# ── Cookie Domain (auth cross-subdomain) ─────────────────────────────────────
# Set to your production domain only. Leave empty for localhost.
# COOKIE_DOMAIN=.splashdeals.rs

# ── Infrastructure ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_NODE_LABEL="LOCAL"
